/**
 * @file tsconfig.json
 * @description Static analysis and type-validation policy for GaborNeuroFit.
 * Establishes strict compilation boundaries to ensure clinical logic 
 * integrity and optimal bundling compatibility with Vite.
 */
{
  "compilerOptions": {
    /* Context: Target environment and module resolution strategy */
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Context: Bundler integration (Vite-optimized delivery) */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    /** @architecture Type-check only: Vite handles the actual transpilation. */
    "noEmit": true,

    /* Context: Strict clinical type-validation rules */
    /** @clinical Strict Mode: mandatory to prevent null-pointer leaks in vergence math. */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src/**/*.ts", 
    "scripts/**/*.ts", 
    "vite.config.ts", 
    "playwright.config.ts"
  ],
  "exclude": [
    "node_modules", 
    "dist", 
    "public"
  ]
}