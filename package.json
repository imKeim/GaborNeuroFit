{
  "name": "gabor-neuro-fit",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build-assets && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config=playwright.config.js",
    "test:e2e:ui": "playwright test --config=playwright.config.js --ui",
    "build-assets": "npx tsx scripts/generate-assets.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "jsdom": "^29.1.1",
    "sharp": "^0.33.2",
    "typescript": "^5.4.5",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
